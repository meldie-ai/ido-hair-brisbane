# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git

# The inbox where booking notifications will be received — replace with Ido Hair's actual email
SALON_EMAIL=hello@idohairbrisbane.com.au

# The Gmail account used to send emails — replace with the sending account
SENDER_EMAIL=hello@idohairbrisbane.com.au

# Gmail app password for the sending account (NOT the regular password)
# Generate one at: https://myaccount.google.com/apppasswords
SENDER_PASSWORD=your_gmail_app_password_here

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Project Settings → API → service_role key (keep secret, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Admin dashboard ───────────────────────────────────────────────────────────
# The password the salon owner uses to log in to /admin
ADMIN_PASSWORD=choose_a_strong_password_here

# A random secret used to sign session cookies — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=generate_a_random_64_char_hex_string_here
